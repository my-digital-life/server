✅ STEP 1 — Install required packages

sudo apt install -y curl unzip wget ca-certificates fonts-powerline fonts-firacode zsh fzf git

✅ STEP 2 — Install Oh‑My‑Posh (official installer)

curl -s https://ohmyposh.dev/install.sh | bash -s

✅ STEP 3 — Download the Kali theme

mkdir -p ~/.cache/oh-my-posh/themes
wget -O ~/.cache/oh-my-posh/themes/kali.omp.json \
https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/kali.omp.json

✅ STEP 4 — Install ZSH plugins

git clone https://github.com/zsh-users/zsh-autosuggestions ~/.zsh-autosuggestions
git clone https://github.com/zsh-users/zsh-syntax-highlighting ~/.zsh-syntax-highlighting
git clone https://github.com/zsh-users/zsh-history-substring-search ~/.zsh-history-substring-search

✅ STEP 5 — FIX THE PATH ISSUE (IMPORTANT)
This ensures Oh‑My‑Posh loads automatically on every reboot.

Create .zprofile:

cat > ~/.zprofile << 'EOF'
# Ensure local bin is available before ZSH loads anything
export PATH="$HOME/.local/bin:$PATH"
EOF


✅ STEP 6 — Create a clean .zshrc


cat > ~/.zshrc << 'EOF'
# --- HISTORY ---
export HISTFILE=~/.zsh_history
export HISTSIZE=50000
export SAVEHIST=50000
setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY

# --- OH MY POSH (KALI THEME) ---
eval "$(oh-my-posh init zsh --config ~/.cache/oh-my-posh/themes/kali.omp.json)"

# --- PLUGINS ---
source ~/.zsh-autosuggestions/zsh-autosuggestions.zsh
source ~/.zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source ~/.zsh-history-substring-search/zsh-history-substring-search.zsh

# --- FZF ---
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/doc/fzf/examples/completion.zsh ] && source /usr/share/doc/fzf/examples/completion.zsh

# --- HISTORY SUBSTRING SEARCH KEYBINDINGS ---
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '^[OA' history-substring-search-up
bindkey '^[OB' history-substring-search-down
EOF

✅ STEP 7 — Make ZSH your default shell

chsh -s /usr/bin/zsh

Reload:

exec zsh
